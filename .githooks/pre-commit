#!/usr/bin/env bash
# Repo-local pre-commit: runs backend pytest + mobile jest against STAGED
# changes. Skip with `git commit --no-verify` when you need to (hook
# bypasses are logged in the commit trailer of any future CI run).
#
# Enable once per clone:
#   git config core.hooksPath .githooks
#
# Fast-path: skip tests for commits that don't touch code (docs/schema-only
# changes still run tests because they can break migrations).

set -euo pipefail

ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT"

changed_backend=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^backend/.*\.(py)$' || true)
changed_mobile=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^mobile/.*\.(ts|tsx|js|jsx)$' || true)

fail=0

# ── Secrets scan ──────────────────────────────────────────────────────
# Block commits that contain likely secrets: API keys, tokens, passwords,
# connection strings, or private keys. Runs on ALL staged files regardless
# of which stack changed — secrets can land anywhere.
echo "→ secrets scan"
secrets_pattern='(PRIVATE.KEY|-----BEGIN.*PRIVATE|password\s*=\s*["\x27][^"\x27]{8}|api[_-]?key\s*=\s*["\x27]|secret\s*=\s*["\x27]|sk-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{36}|postgresql://[^@]+:[^@]+@|Bearer\s+ey[A-Za-z0-9])'
matched=$(git diff --cached --diff-filter=ACMR -U0 | grep -iEn "$secrets_pattern" | grep -v '^\-\-\-\|^+++\|^#\|//.*secret\|\.example\|test.*fixture\|mock\|placeholder' || true)
if [ -n "$matched" ]; then
  echo "  ✗ Possible secrets detected in staged changes:"
  echo "$matched" | head -10
  echo
  echo "  If these are false positives (test fixtures, examples), bypass with --no-verify."
  fail=1
else
  echo "  ✓ No secrets found"
fi

if [ -n "$changed_backend" ]; then
  echo "→ backend pytest"
  if [ -x "backend/venv/bin/pytest" ]; then
    (cd backend && venv/bin/pytest -q) || fail=1
  else
    echo "  ✗ backend/venv/bin/pytest not found — cannot run tests for staged .py changes."
    echo "    Install: cd backend && python -m venv venv && venv/bin/pip install -r requirements.txt"
    echo "    Bypass (if you really must): git commit --no-verify"
    fail=1
  fi
else
  echo "→ backend pytest skipped (no backend/*.py staged)"
fi

if [ -n "$changed_mobile" ]; then
  echo "→ mobile jest"
  if [ -d "mobile/node_modules" ]; then
    (cd mobile && npx --no-install jest --silent) || fail=1
  else
    echo "  ✗ mobile/node_modules not found — cannot run tests for staged .ts(x) changes."
    echo "    Install: cd mobile && npm install"
    echo "    Bypass (if you really must): git commit --no-verify"
    fail=1
  fi
else
  echo "→ mobile jest skipped (no mobile/*.ts(x) staged)"
fi

if [ "$fail" = "1" ]; then
  echo
  echo "✗ Pre-commit failed. Fix the failures above or bypass with --no-verify."
  exit 1
fi
echo "✓ Pre-commit passed."

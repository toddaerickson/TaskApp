# Copy to .env for local use, or set in Vercel project settings for prod.
# EXPO_PUBLIC_* vars are public — anything here ships inside the client bundle.

# Leave unset locally (defaults to http://localhost:8000).
# Set to your Fly.io URL in production, e.g.:
#   EXPO_PUBLIC_API_URL=https://taskapp-backend.fly.dev
EXPO_PUBLIC_API_URL=

{
  "expo": {
    "name": "TaskApp",
    "slug": "taskapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "taskapp",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a73e8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.taskapp.tasks",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Unlock TaskApp with Face ID instead of entering your PIN."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a73e8"
      },
      "package": "com.taskapp.tasks"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Unlock TaskApp with Face ID instead of entering your PIN."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#1a73e8"
        }
      ]
    ]
  }
}

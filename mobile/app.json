{
  "expo": {
    "name": "TaskApp",
    "slug": "taskapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "taskapp",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.taskapp.tasks",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Unlock TaskApp with Face ID instead of entering your PIN."
      }
    },
    "android": {
      "package": "com.taskapp.tasks"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Unlock TaskApp with Face ID instead of entering your PIN."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#1a73e8"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font"
    ]
  }
}
